{
  "name": "re-commerce-enterprise",
  "version": "1.0.0",
  "description": "Mr. RE:commerce Enterprise System - Hybrid dokumentation och auto-deployment med superkrafter",
  "main": "src/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:preview": "playwright test --config=playwright.preview.config.js",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:smoke": "jest --testPathPattern=tests/smoke",
    "test:a11y": "jest --testPathPattern=tests/accessibility",
    "test:a11y:report": "jest --testPathPattern=tests/accessibility --reporters=default --reporters=jest-html-reporters",
    "test:visual": "playwright test --config=playwright.visual.config.js",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t re-commerce-enterprise .",
    "docker:run": "docker run -p 3000:3000 re-commerce-enterprise",
    "k8s:deploy": "./scripts/deploy.sh",
    "k8s:rollback": "./scripts/rollback.sh",
    "backup": "./scripts/backup.sh",
    "clean": "rm -rf .next node_modules dist coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^1.7.0",
    "@heroicons/react": "^2.0.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.0.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^4.29.0",
    "aws-sdk": "^2.1400.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.3.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "d3": "^7.8.0",
    "date-fns": "^2.30.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-session": "^1.17.3",
    "framer-motion": "^10.12.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.535.0",
    "mammoth": "^1.9.1",
    "multer": "^1.4.5-lts.1",
    "next": "^14.0.0",
    "next-auth": "^4.24.11",
    "nodemailer": "^6.9.0",
    "passport": "^0.6.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "plotly.js": "^3.0.3",
    "prisma": "^5.0.0",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^1.4.0",
    "react-hook-form": "^7.44.0",
    "react-hot-toast": "^2.5.2",
    "react-plotly.js": "^2.6.0",
    "react-resizable": "^3.0.5",
    "recharts": "^3.1.0",
    "redis": "^4.6.0",
    "sharp": "^0.32.0",
    "stripe": "^12.0.0",
    "styled-components": "^6.0.0",
    "tailwindcss": "^3.3.0",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "zod": "^3.21.0",
    "zustand": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.7.0",
    "@jest/globals": "^29.5.0",
    "@lhci/cli": "^0.12.0",
    "@playwright/test": "^1.35.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/lodash": "^4.14.195",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.8",
    "@types/passport": "^1.0.12",
    "@types/passport-github2": "^1.2.5",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/passport-jwt": "^3.0.8",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "autoprefixer": "^10.4.14",
    "axe-core": "^4.7.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.42.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "http-proxy-middleware": "^3.0.5",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-html-reporters": "^3.1.4",
    "lighthouse": "^10.2.0",
    "lint-staged": "^13.2.0",
    "nodemon": "^2.0.22",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/re-commerce-enterprise.git"
  },
  "keywords": [
    "e-commerce",
    "dashboard",
    "widgets",
    "scene-builder",
    "nextjs",
    "kubernetes",
    "ci-cd",
    "auto-deployment"
  ],
  "author": "Your Organization",
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/.next/",
      "<rootDir>/node_modules/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.{js,jsx,ts,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
